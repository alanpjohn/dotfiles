{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "opencode-gemini-auth@latest",
        "opencode-pty",
        "./plugins/custom-utils"
    ],
    "autoupdate": true,
    // Agent configuration for delegation
    "agent": {
        // Build Primary Agents
        "architect": {
            "prompt": "{file:./agent/architect.md}",
            "mode": "primary",
            "tools": {
                "task": true,
            },
            "permission": {
                "task": {
                    "peer": "allow",
                    "reviewer": "allow",
                    "librarian": "allow",
                    "explore": "allow",
                    "*": "deny",
                },
            },
        },
        "engineer": {
            "prompt": "{file:./agent/engineer.md}",
            "mode": "primary",
            "tools": {
                "task": true,
            },
            "permission": {
                "task": {
                    "worker": "allow",
                    "explore": "allow",
                    "librarian": "allow",
                    "oracle": "allow",
                    "*": "deny",
                },
            },
        },
        "researcher": {
            "prompt": "{file:./agent/researcher.md}",
            "mode": "primary",
            "tools": {
                "task": true,
            },
            "permission": {
                "task": {
                    "explore": "allow",
                    "librarian": "allow",
                    "oracle": "allow",
                    "*": "deny",
                },
            },
        },
        "scribe": {
            "prompt": "{file:./agent/scribe.md}",
            "mode": "primary",
        },
        // Subagents
        "peer": {
            "prompt": "{file:./agent/peer.md}",
            "mode": "subagent",
        },
        "reviewer": {
            "prompt": "{file:./agent/reviewer.md}",
            "mode": "subagent",
        },
        "librarian": {
            "prompt": "{file:./agent/librarian.md}",
            "mode": "subagent",
        },
        "oracle": {
            "prompt": "{file:./agent/oracle.md}",
            "mode": "subagent",
        },
        "worker": {
            "prompt": "{file:./agent/worker.md}",
            "mode": "subagent",
        },
    },
}
